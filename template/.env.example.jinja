# Dev config file loading
DEV_CONFIG_FILE=config.local.yaml
DEV_LOAD_DOTENV=true

# Service metadata
SERVICE_NAME={{ service_name }}
SERVICE_MODULE_PATH={{ module_path }}

# Transports
HTTP_ENABLED={{ "true" if http_enabled else "false" }}
HTTP_PORT=80
GRPC_ENABLED={{ "true" if grpc_enabled else "false" }}
GRPC_PORT=82

{%- if pg_enabled %}

# PostgreSQL
PG_ENABLED=false
PG_DSN=postgres://postgres:postgres@127.0.0.1:5432/postgres?sslmode=disable
PG_MAX_CONNS=4
PG_CONN_MAX_LIFETIME=30m
{%- endif %}

{%- if kafka_enabled %}

# Kafka
KAFKA_ENABLED=false
KAFKA_PRODUCER_ENABLED={{ "true" if kafka_producer_enabled else "false" }}
KAFKA_CONSUMER_ENABLED={{ "true" if kafka_consumer_enabled else "false" }}
KAFKA_BROKERS=127.0.0.1:19092
KAFKA_CLIENT_ID={{ service_name }}
KAFKA_TOPIC_OUT={{ service_name }}.events.v1
KAFKA_TOPIC_IN={{ service_name }}.events.v1
KAFKA_GROUP_ID={{ service_name }}.group.v1
{%- endif %}
