package ping

import (
	"context"
	"testing"

	"{{ module_path }}/internal/pkg/model"
)

func TestServicePingSuccess(t *testing.T) {
	t.Parallel()

	svc := New("svc")
	resp, err := svc.Ping(context.Background(), model.PingRequest{})
	if err != nil {
		t.Fatalf("unexpected error: %v", err)
	}
	if resp.Status != "ok" {
		t.Fatalf("unexpected status: %q", resp.Status)
	}
	if resp.Service != "svc" {
		t.Fatalf("unexpected service: %q", resp.Service)
	}
}

func TestServicePingForcedErrors(t *testing.T) {
	t.Parallel()

	testCases := []struct {
		name       string
		forceError string
		expected   error
	}{
		{name: "not found", forceError: model.ForceErrorNotFound, expected: model.ErrNotFound},
		{name: "invalid argument", forceError: model.ForceErrorInvalidArgument, expected: model.ErrInvalidArgument},
		{name: "already exists", forceError: model.ForceErrorAlreadyExists, expected: model.ErrUniqueViolation},
		{name: "failed precondition", forceError: model.ForceErrorFailedPrecondition, expected: model.ErrRevisionMismatch},
		{name: "unknown token", forceError: "unknown", expected: model.ErrInvalidArgument},
	}

	svc := New("svc")
	for _, tc := range testCases {
		tc := tc
		t.Run(tc.name, func(t *testing.T) {
			t.Parallel()
			_, err := svc.Ping(context.Background(), model.PingRequest{ForceError: tc.forceError})
			if err == nil {
				t.Fatalf("expected error %v, got nil", tc.expected)
			}
			if err != tc.expected {
				t.Fatalf("expected error %v, got %v", tc.expected, err)
			}
		})
	}
}
