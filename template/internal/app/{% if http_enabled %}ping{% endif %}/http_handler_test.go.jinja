package ping

import (
	"context"
	"encoding/json"
	"errors"
	"net/http"
	"net/http/httptest"
	"testing"

	"{{ module_path }}/internal/pkg/model"
)

type httpStubService struct {
	resp model.PingResponse
	err  error
}

func (s *httpStubService) Ping(_ context.Context, _ model.PingRequest) (model.PingResponse, error) {
	return s.resp, s.err
}

func TestHTTPPingSuccess(t *testing.T) {
	t.Parallel()

	h := NewHTTPHandler(&httpStubService{resp: model.PingResponse{Status: "ok", Service: "svc"}})
	req := httptest.NewRequest(http.MethodGet, "/v1/ping", nil)
	w := httptest.NewRecorder()

	h.Ping(w, req)

	if w.Code != http.StatusOK {
		t.Fatalf("unexpected status: %d", w.Code)
	}

	var payload model.PingResponse
	if err := json.Unmarshal(w.Body.Bytes(), &payload); err != nil {
		t.Fatalf("decode response: %v", err)
	}
	if payload.Status != "ok" || payload.Service != "svc" {
		t.Fatalf("unexpected payload: %+v", payload)
	}
}

func TestHTTPHealthEndpoints(t *testing.T) {
	t.Parallel()

	h := NewHTTPHandler(&httpStubService{})

	testCases := []struct {
		name         string
		path         string
		handler      func(http.ResponseWriter, *http.Request)
		expectedCode int
	}{
		{name: "healthz", path: "/healthz", handler: h.Healthz, expectedCode: http.StatusOK},
		{name: "readyz", path: "/readyz", handler: h.Readyz, expectedCode: http.StatusOK},
	}

	for _, tc := range testCases {
		tc := tc
		t.Run(tc.name, func(t *testing.T) {
			t.Parallel()

			req := httptest.NewRequest(http.MethodGet, tc.path, nil)
			w := httptest.NewRecorder()

			tc.handler(w, req)

			if w.Code != tc.expectedCode {
				t.Fatalf("unexpected status: got %d want %d", w.Code, tc.expectedCode)
			}

			var payload map[string]string
			if err := json.Unmarshal(w.Body.Bytes(), &payload); err != nil {
				t.Fatalf("decode response: %v", err)
			}
			if payload["status"] != "ok" {
				t.Fatalf("unexpected status payload: %q", payload["status"])
			}
		})
	}
}

func TestHTTPPingKnownDomainError(t *testing.T) {
	t.Parallel()

	h := NewHTTPHandler(&httpStubService{err: model.ErrNotFound})
	req := httptest.NewRequest(http.MethodGet, "/v1/ping", nil)
	w := httptest.NewRecorder()

	h.Ping(w, req)

	if w.Code != http.StatusNotFound {
		t.Fatalf("unexpected status: %d", w.Code)
	}

	var payload map[string]string
	if err := json.Unmarshal(w.Body.Bytes(), &payload); err != nil {
		t.Fatalf("decode response: %v", err)
	}
	if payload["reason"] != "NOT_FOUND" {
		t.Fatalf("unexpected reason: %q", payload["reason"])
	}
}

func TestHTTPPingUnknownError(t *testing.T) {
	t.Parallel()

	h := NewHTTPHandler(&httpStubService{err: errors.New("boom")})
	req := httptest.NewRequest(http.MethodGet, "/v1/ping", nil)
	w := httptest.NewRecorder()

	h.Ping(w, req)

	if w.Code != http.StatusInternalServerError {
		t.Fatalf("unexpected status: %d", w.Code)
	}
}
