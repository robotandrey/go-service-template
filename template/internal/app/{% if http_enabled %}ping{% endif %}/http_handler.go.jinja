package ping

import (
	"encoding/json"
	"log"
	"net/http"
	"strconv"
	"time"

	"{{ module_path }}/internal/app/errorx"
	"{{ module_path }}/internal/pkg/model"
)

const readHeaderTimeout = 5 * time.Second

type HTTPHandler struct {
	pingService Service
}

type httpErrorResponse struct {
	Error  string `json:"error"`
	Reason string `json:"reason,omitempty"`
}

type healthResponse struct {
	Status string `json:"status"`
}

func NewHTTPServer(port int, pingService Service) *http.Server {
	handler := NewHTTPHandler(pingService)
	mux := http.NewServeMux()
	mux.HandleFunc("GET /healthz", handler.Healthz)
	mux.HandleFunc("GET /readyz", handler.Readyz)
	mux.HandleFunc("GET /v1/ping", handler.Ping)

	return &http.Server{
		Addr:              ":" + strconv.Itoa(port),
		Handler:           mux,
		ReadHeaderTimeout: readHeaderTimeout,
	}
}

func NewHTTPHandler(pingService Service) *HTTPHandler {
	return &HTTPHandler{pingService: pingService}
}

func (h *HTTPHandler) Healthz(w http.ResponseWriter, _ *http.Request) {
	w.Header().Set("Content-Type", "application/json")
	w.WriteHeader(http.StatusOK)
	if encErr := json.NewEncoder(w).Encode(healthResponse{Status: "ok"}); encErr != nil {
		log.Printf("encode healthz response: %v", encErr)
	}
}

func (h *HTTPHandler) Readyz(w http.ResponseWriter, _ *http.Request) {
	w.Header().Set("Content-Type", "application/json")
	w.WriteHeader(http.StatusOK)
	if encErr := json.NewEncoder(w).Encode(healthResponse{Status: "ok"}); encErr != nil {
		log.Printf("encode readyz response: %v", encErr)
	}
}

func (h *HTTPHandler) Ping(w http.ResponseWriter, r *http.Request) {
	resp, err := h.pingService.Ping(r.Context(), model.PingRequest{
		ForceError: r.URL.Query().Get("error"),
	})
	if err != nil {
		h.writeError(w, err)
		return
	}

	w.Header().Set("Content-Type", "application/json")
	w.WriteHeader(http.StatusOK)
	if encErr := json.NewEncoder(w).Encode(resp); encErr != nil {
		log.Printf("encode ping response: %v", encErr)
	}
}

func (h *HTTPHandler) writeError(w http.ResponseWriter, err error) {
	statusCode := errorx.HTTPStatusFromError(err)
	reason, _ := errorx.ReasonFromError(err)

	w.Header().Set("Content-Type", "application/json")
	w.WriteHeader(statusCode)
	if encErr := json.NewEncoder(w).Encode(httpErrorResponse{Error: err.Error(), Reason: reason}); encErr != nil {
		log.Printf("encode error response: %v", encErr)
	}
}
