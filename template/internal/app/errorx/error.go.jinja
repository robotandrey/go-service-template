package errorx

import (
	"errors"
	"net/http"

	"{{ module_path }}/internal/pkg/model"
)

const (
	ReasonNotFound         = "NOT_FOUND"
	ReasonInvalidArgument  = "INVALID_ARGUMENT"
	ReasonUniqueViolation  = "UNIQUE_VIOLATION"
	ReasonRevisionMismatch = "REVISION_MISMATCH"
)

func ReasonFromError(err error) (string, bool) {
	switch {
	case errors.Is(err, model.ErrNotFound):
		return ReasonNotFound, true
	case errors.Is(err, model.ErrInvalidArgument):
		return ReasonInvalidArgument, true
	case errors.Is(err, model.ErrUniqueViolation):
		return ReasonUniqueViolation, true
	case errors.Is(err, model.ErrRevisionMismatch):
		return ReasonRevisionMismatch, true
	default:
		return "", false
	}
}

func HTTPStatusFromError(err error) int {
	reason, ok := ReasonFromError(err)
	if !ok {
		return http.StatusInternalServerError
	}

	switch reason {
	case ReasonNotFound:
		return http.StatusNotFound
	case ReasonInvalidArgument:
		return http.StatusBadRequest
	case ReasonUniqueViolation:
		return http.StatusConflict
	case ReasonRevisionMismatch:
		return http.StatusPreconditionFailed
	default:
		return http.StatusInternalServerError
	}
}
