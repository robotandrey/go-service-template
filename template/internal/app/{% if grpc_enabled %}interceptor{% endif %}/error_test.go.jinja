package interceptor

import (
	"context"
	"errors"
	"testing"

	"{{ module_path }}/internal/app/errorx"
	"{{ module_path }}/internal/pkg/model"
	"google.golang.org/genproto/googleapis/rpc/errdetails"
	"google.golang.org/grpc"
	"google.golang.org/grpc/codes"
	"google.golang.org/grpc/status"
)

func TestErrorHandlingInterceptorKnownErrors(t *testing.T) {
	t.Parallel()

	testCases := []struct {
		name           string
		inErr          error
		expectedCode   codes.Code
		expectedReason string
	}{
		{name: "not found", inErr: model.ErrNotFound, expectedCode: codes.NotFound, expectedReason: errorx.ReasonNotFound},
		{name: "invalid argument", inErr: model.ErrInvalidArgument, expectedCode: codes.InvalidArgument, expectedReason: errorx.ReasonInvalidArgument},
		{name: "already exists", inErr: model.ErrUniqueViolation, expectedCode: codes.AlreadyExists, expectedReason: errorx.ReasonUniqueViolation},
		{name: "failed precondition", inErr: model.ErrRevisionMismatch, expectedCode: codes.FailedPrecondition, expectedReason: errorx.ReasonRevisionMismatch},
	}

	for _, tc := range testCases {
		tc := tc
		t.Run(tc.name, func(t *testing.T) {
			t.Parallel()

			_, err := ErrorHandlingInterceptor(context.Background(), nil, &grpc.UnaryServerInfo{}, mkHandler(tc.inErr))
			if err == nil {
				t.Fatalf("expected error")
			}

			st, ok := status.FromError(err)
			if !ok {
				t.Fatalf("expected grpc status error, got %T: %v", err, err)
			}
			if st.Code() != tc.expectedCode {
				t.Fatalf("unexpected code: got %s want %s", st.Code(), tc.expectedCode)
			}

			reason := extractReason(st)
			if reason != tc.expectedReason {
				t.Fatalf("unexpected reason: got %q want %q", reason, tc.expectedReason)
			}
		})
	}
}

func TestErrorHandlingInterceptorUnknownError(t *testing.T) {
	t.Parallel()

	originalErr := errors.New("unknown")
	_, err := ErrorHandlingInterceptor(context.Background(), nil, &grpc.UnaryServerInfo{}, mkHandler(originalErr))
	if err == nil {
		t.Fatal("expected error")
	}

	if _, ok := status.FromError(err); ok {
		t.Fatalf("unexpected grpc status wrapping for unknown error: %v", err)
	}
	if err != originalErr {
		t.Fatalf("expected same error instance")
	}
}

func mkHandler(retErr error) grpc.UnaryHandler {
	return func(_ context.Context, _ interface{}) (interface{}, error) {
		return nil, retErr
	}
}

func extractReason(st *status.Status) string {
	for _, detail := range st.Details() {
		if info, ok := detail.(*errdetails.ErrorInfo); ok {
			return info.Reason
		}
	}

	return ""
}
