package config

import (
	"fmt"
	"os"
	"strings"

	"github.com/caarlos0/env/v11"
	"github.com/joho/godotenv"
	"gopkg.in/yaml.v3"
)

func MustLoad() AppConfig {
	cfg, err := Load()
	if err != nil {
		panic(fmt.Sprintf("config: %v", err))
	}
	return cfg
}

func Load() (AppConfig, error) {
	_ = godotenv.Load(".deploy/config/.env.local", ".deploy/config/.env", ".env.local", ".env")

	cfg := DefaultConfig()
	if err := applyYAMLFiles(&cfg, discoverConfigPaths()); err != nil {
		return AppConfig{}, err
	}

	if err := env.Parse(&cfg); err != nil {
		return AppConfig{}, fmt.Errorf("parse env: %w", err)
	}

	if err := cfg.Validate(); err != nil {
		return AppConfig{}, err
	}

	return cfg, nil
}

func discoverConfigPaths() []string {
	if custom := strings.TrimSpace(os.Getenv("CONFIG_PATH")); custom != "" {
		parts := strings.Split(custom, ",")
		paths := make([]string, 0, len(parts))
		for _, part := range parts {
			part = strings.TrimSpace(part)
			if part != "" {
				paths = append(paths, part)
			}
		}
		if len(paths) > 0 {
			return paths
		}
	}

	return []string{
		".deploy/config/config.yaml",
		".deploy/config/config.local.yaml",
		"config.yaml",
		"config.local.yaml",
	}
}

func applyYAMLFiles(cfg *AppConfig, paths []string) error {
	for _, path := range paths {
		if strings.TrimSpace(path) == "" {
			continue
		}

		b, err := os.ReadFile(path)
		if err != nil {
			if os.IsNotExist(err) {
				continue
			}
			return fmt.Errorf("read config yaml %q: %w", path, err)
		}

		if len(strings.TrimSpace(string(b))) == 0 {
			continue
		}

		if err := yaml.Unmarshal(b, cfg); err != nil {
			return fmt.Errorf("decode config yaml %q: %w", path, err)
		}
	}

	return nil
}
