FROM golang:1.23-alpine AS builder

WORKDIR /src

COPY go.mod go.sum* ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -o /out/service ./cmd/{{ service_name }}

FROM alpine:3.20

WORKDIR /app
RUN apk add --no-cache ca-certificates wget busybox-extras \
    && addgroup -S app \
    && adduser -S -G app app
COPY --from=builder /out/service /app/service
USER app

EXPOSE 80 82
ENTRYPOINT ["/app/service"]
